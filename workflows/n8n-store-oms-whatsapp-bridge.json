      "parameters": {
        "jsCode": "// Verify X-OMS-Signature when OMS_N8N_HMAC_SECRET is set (same value as tenant n8nWebhookSecret or N8N_HMAC_SECRET).\n// Requires Webhook option \"Raw Body\" = true (set above).\nconst crypto = require('crypto');\nconst root = $input.first().json;\nconst headers = root.headers || {};\nconst sig = headers['x-oms-signature'] || headers['X-OMS-Signature'];\nconst secret = $env.OMS_N8N_HMAC_SECRET || '';\n\nif (secret && sig && typeof root.rawBody === 'string') {\n  const expected = crypto.createHmac('sha256', secret).update(root.rawBody, 'utf8').digest('hex');\n  if (expected !== sig) {\n    throw new Error('Invalid X-OMS-Signature');\n  }\n}\n\nconst b = root.body;\nif (!b || typeof b !== 'object') {\n  throw new Error('Missing JSON body');\n}\nreturn [{ json: b }];"
      },
