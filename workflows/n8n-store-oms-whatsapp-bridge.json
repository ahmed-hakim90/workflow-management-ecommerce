    {
      "parameters": {
        "jsCode": "// Keyword routing for inbound WhatsApp (fallback if you do not use LLM).\n// Uses metadata.linkedOrderId from OMS when the thread is linked to an order.\nconst j = $input.first().json;\nconst orderId = j.metadata?.linkedOrderId || j.orderId || '';\nconst text = String(j.body || '').toLowerCase();\nlet action = null;\nif (/موافق|تمام|yes|ok|okay|أكد|اكد|confirm/.test(text)) action = 'confirm';\nelse if (/إلغاء|الغاء|cancel|الغي|ألغي/.test(text)) action = 'cancel';\nif (!orderId || !action) {\n  return [{ json: { ...j, _omsAutomation: 'skip', _reason: !orderId ? 'no_linked_order' : 'no_keyword_match' } }];\n}\nreturn [{ json: { ...j, _omsAutomation: 'call_oms', action, orderId } }];"
      },
